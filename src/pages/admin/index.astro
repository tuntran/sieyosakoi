---
import { env } from 'cloudflare:workers';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getOpenBatch, getDashboardStats, getRecentOrders } from '../../lib/db';

const db = env.DB;
const batch = await getOpenBatch(db);
const stats = batch ? await getDashboardStats(db, batch.id) : null;
const recentOrders = batch ? await getRecentOrders(db, batch.id, 10) : [];

function fmtVnd(n: number) { return n.toLocaleString('vi-VN') + 'đ'; }
function fmtDate(ts: number) {
  return new Date(ts * 1000).toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh', day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' });
}

const paymentLabels: Record<string, string> = { awaiting: 'Chờ CK', verified: 'Đã CK', refunded: 'Hoàn tiền' };
const orderLabels: Record<string, string> = { pending: 'Chờ xử lý', confirmed: 'Đã xác nhận', done: 'Hoàn thành', cancelled: 'Đã huỷ' };
---

<AdminLayout title="Dashboard" currentPage="dashboard">
  {!batch ? (
    <div class="alert alert-info">Chưa có đợt bán nào đang mở.</div>
  ) : (
    <>
      <!-- Stats -->
      <div class="stats-grid">
        <div class="stat-card accent-sky">
          <div class="stat-label">Đơn hôm nay</div>
          <div class="stat-value">{stats?.total_orders ?? 0}</div>
          <div class="stat-sub">tổng đợt này</div>
        </div>
        <a href="/admin/orders?payment_status=awaiting" class="stat-card accent-red stat-card-link">
          <div class="stat-label">Chờ xác nhận CK</div>
          <div class="stat-value">{stats?.pending_payment ?? 0}</div>
          <div class="stat-sub">Tap để xem →</div>
        </a>
        <div class="stat-card accent-teal">
          <div class="stat-label">Đã xác nhận</div>
          <div class="stat-value">{stats?.confirmed_orders ?? 0}</div>
          <div class="stat-sub">đơn</div>
        </div>
        <div class="stat-card accent-orange">
          <div class="stat-label">Doanh thu (đã CK)</div>
          <div class="stat-value" style="font-size:1.25rem">{fmtVnd(stats?.total_revenue ?? 0)}</div>
          <div class="stat-sub">chờ: {fmtVnd(stats?.pending_revenue ?? 0)}</div>
        </div>
      </div>

      <!-- Batch info -->
      <div class="card">
        <div class="card-header">
          <span class="card-title">🗂️ Đợt bán hiện tại</span>
          <a href="/admin/batches" class="btn btn-outline btn-sm">Xem tất cả</a>
        </div>
        <div class="card-body" style="display:flex;gap:24px;flex-wrap:wrap;align-items:center">
          <div>
            <div style="font-size:0.75rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.06em">Tên đợt</div>
            <div style="font-weight:700;font-size:1rem">{batch.name}</div>
          </div>
          <div>
            <div style="font-size:0.75rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.06em">Trạng thái</div>
            <span class={`badge badge-${batch.status}`}>{batch.status === 'open' ? '● Đang mở' : batch.status}</span>
          </div>
          {batch.close_at && (
            <div>
              <div style="font-size:0.75rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.06em">Deadline</div>
              <div style="font-weight:600">{fmtDate(batch.close_at)}</div>
            </div>
          )}
        </div>
      </div>

      <!-- Recent orders -->
      <div class="card">
        <div class="card-header">
          <span class="card-title">📋 Đơn hàng gần nhất</span>
          <a href="/admin/orders" class="btn btn-outline btn-sm">Xem tất cả</a>
        </div>
        {recentOrders.length === 0 ? (
          <div class="card-body" style="color:var(--text-muted);font-size:0.875rem">Chưa có đơn hàng nào.</div>
        ) : (
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Mã đơn</th>
                  <th>Khách hàng</th>
                  <th>Tổng tiền</th>
                  <th>Thanh toán</th>
                  <th>Đơn hàng</th>
                  <th>Ngày đặt</th>
                </tr>
              </thead>
              <tbody>
                {recentOrders.map(o => (
                  <tr>
                    <td><a href={`/admin/orders/${o.id}`}>{o.id}</a></td>
                    <td>
                      <div style="font-weight:600">{o.customer_name}</div>
                      <div style="font-size:0.78rem;color:var(--text-muted)">{o.phone}</div>
                    </td>
                    <td style="font-weight:700">{fmtVnd(o.total)}</td>
                    <td><span class={`badge badge-${o.payment_status}`}>{paymentLabels[o.payment_status] ?? o.payment_status}</span></td>
                    <td><span class={`badge badge-${o.order_status}`}>{orderLabels[o.order_status] ?? o.order_status}</span></td>
                    <td style="font-size:0.8rem;white-space:nowrap">{fmtDate(o.created_at)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </>
  )}
</AdminLayout>
