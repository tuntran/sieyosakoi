---
import { env } from 'cloudflare:workers';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getOpenBatch, getDashboardStats, getRecentOrders, getPaymentStatusBreakdown, getOrderStatusBreakdown, getSalesSummary } from '../../lib/db';

const db = env.DB;
const batch = await getOpenBatch(db);

let stats: Awaited<ReturnType<typeof getDashboardStats>> | null = null;
let recentOrders: Awaited<ReturnType<typeof getRecentOrders>> = [];
let paymentBreakdown: Record<string, number> = {};
let orderBreakdown: Record<string, number> = {};
let topProducts: { name: string; verified: number; awaiting: number; cancelled: number }[] = [];

if (batch) {
  const [s, ro, pb, ob, ss] = await Promise.all([
    getDashboardStats(db, batch.id),
    getRecentOrders(db, batch.id, 10),
    getPaymentStatusBreakdown(db, batch.id),
    getOrderStatusBreakdown(db, batch.id),
    getSalesSummary(db, batch.id),
  ]);
  stats = s;
  recentOrders = ro;
  paymentBreakdown = pb;
  orderBreakdown = ob;

  // Aggregate sales by product name, take top 10
  const productMap: Record<string, { verified: number; awaiting: number; cancelled: number }> = {};
  for (const row of ss) {
    if (!productMap[row.product_name]) {
      productMap[row.product_name] = { verified: 0, awaiting: 0, cancelled: 0 };
    }
    productMap[row.product_name].verified += row.verified_qty;
    productMap[row.product_name].awaiting += row.awaiting_qty;
    productMap[row.product_name].cancelled += row.cancelled_qty;
  }
  topProducts = Object.entries(productMap)
    .map(([name, d]) => ({ name, ...d }))
    .sort((a, b) => (b.verified + b.awaiting) - (a.verified + a.awaiting))
    .slice(0, 10);
}

function fmtVnd(n: number) { return n.toLocaleString('vi-VN') + 'đ'; }
function fmtDate(ts: number) {
  return new Date(ts * 1000).toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh', day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' });
}

const paymentLabels: Record<string, string> = { awaiting: 'Chờ CK', verified: 'Đã CK', refunded: 'Hoàn tiền' };
const orderLabels: Record<string, string> = { pending: 'Chờ xử lý', confirmed: 'Đã xác nhận', done: 'Hoàn thành', cancelled: 'Đã huỷ' };
---

<AdminLayout title="Dashboard" currentPage="dashboard">
  {!batch ? (
    <div class="alert alert-info">Chưa có đợt bán nào đang mở.</div>
  ) : (
    <>
      <!-- Stats -->
      <div class="stats-grid">
        <div class="stat-card accent-sky">
          <div class="stat-label">Đơn hôm nay</div>
          <div class="stat-value">{stats?.total_orders ?? 0}</div>
          <div class="stat-sub">tổng đợt này</div>
        </div>
        <a href="/admin/orders?payment_status=awaiting" class="stat-card accent-red stat-card-link">
          <div class="stat-label">Chờ xác nhận CK</div>
          <div class="stat-value">{stats?.pending_payment ?? 0}</div>
          <div class="stat-sub">Tap để xem →</div>
        </a>
        <div class="stat-card accent-teal">
          <div class="stat-label">Đã xác nhận</div>
          <div class="stat-value">{stats?.confirmed_orders ?? 0}</div>
          <div class="stat-sub">đơn</div>
        </div>
        <div class="stat-card accent-orange">
          <div class="stat-label">Doanh thu (đã CK)</div>
          <div class="stat-value" style="font-size:1.25rem">{fmtVnd(stats?.total_revenue ?? 0)}</div>
          <div class="stat-sub">chờ: {fmtVnd(stats?.pending_revenue ?? 0)}</div>
        </div>
      </div>

      <!-- Batch info -->
      <div class="card">
        <div class="card-header">
          <span class="card-title">🗂️ Đợt bán hiện tại</span>
          <a href="/admin/batches" class="btn btn-outline btn-sm">Xem tất cả</a>
        </div>
        <div class="card-body" style="display:flex;gap:24px;flex-wrap:wrap;align-items:center">
          <div>
            <div style="font-size:0.75rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.06em">Tên đợt</div>
            <div style="font-weight:700;font-size:1rem">{batch.name}</div>
          </div>
          <div>
            <div style="font-size:0.75rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.06em">Trạng thái</div>
            <span class={`badge badge-${batch.status}`}>{batch.status === 'open' ? '● Đang mở' : batch.status}</span>
          </div>
          {batch.close_at && (
            <div>
              <div style="font-size:0.75rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.06em">Deadline</div>
              <div style="font-weight:600">{fmtDate(batch.close_at)}</div>
            </div>
          )}
        </div>
      </div>

      <!-- Charts -->
      <div class="charts-grid">
        <div class="chart-card">
          <div class="chart-card-title">Thanh toán</div>
          <div class="chart-canvas-wrap"><canvas id="paymentChart"></canvas></div>
        </div>
        <div class="chart-card">
          <div class="chart-card-title">Trạng thái đơn</div>
          <div class="chart-canvas-wrap"><canvas id="orderChart"></canvas></div>
        </div>
      </div>

      <!-- Top products -->
      <div class="card" style="margin-bottom:20px">
        <div class="card-header">
          <span class="card-title">📊 Top sản phẩm bán chạy</span>
        </div>
        <div class="card-body">
          <div class="chart-canvas-wrap" style="max-height:none"><canvas id="productsChart"></canvas></div>
        </div>
      </div>

      <!-- Revenue breakdown -->
      <div class="card" style="margin-bottom:20px">
        <div class="card-header">
          <span class="card-title">💰 Doanh thu</span>
        </div>
        <div class="card-body">
          <div class="chart-canvas-wrap" style="max-height:120px"><canvas id="revenueChart"></canvas></div>
        </div>
      </div>

      <!-- Recent orders -->
      <div class="card">
        <div class="card-header">
          <span class="card-title">📋 Đơn hàng gần nhất</span>
          <a href="/admin/orders" class="btn btn-outline btn-sm">Xem tất cả</a>
        </div>
        {recentOrders.length === 0 ? (
          <div class="card-body" style="color:var(--text-muted);font-size:0.875rem">Chưa có đơn hàng nào.</div>
        ) : (
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Mã đơn</th>
                  <th>Khách hàng</th>
                  <th>Tổng tiền</th>
                  <th>Thanh toán</th>
                  <th>Đơn hàng</th>
                  <th>Ngày đặt</th>
                </tr>
              </thead>
              <tbody>
                {recentOrders.map(o => (
                  <tr>
                    <td><a href={`/admin/orders/${o.id}`}>{o.id}</a></td>
                    <td>
                      <div style="font-weight:600">{o.customer_name}</div>
                      <div style="font-size:0.78rem;color:var(--text-muted)">{o.phone}</div>
                    </td>
                    <td style="font-weight:700">{fmtVnd(o.total)}</td>
                    <td><span class={`badge badge-${o.payment_status}`}>{paymentLabels[o.payment_status] ?? o.payment_status}</span></td>
                    <td><span class={`badge badge-${o.order_status}`}>{orderLabels[o.order_status] ?? o.order_status}</span></td>
                    <td style="font-size:0.8rem;white-space:nowrap">{fmtDate(o.created_at)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </>
  )}
</AdminLayout>

{batch && (
  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  <script define:vars={{ paymentBreakdown, orderBreakdown, topProducts, stats }}>
    document.addEventListener('DOMContentLoaded', () => {
      const fontFamily = "'Noto Sans JP', system-ui, sans-serif";
      Chart.defaults.font.family = fontFamily;
      Chart.defaults.font.size = 12;

      // ── Donut: Payment status ──
      const paymentCtx = document.getElementById('paymentChart');
      if (paymentCtx) {
        new Chart(paymentCtx, {
          type: 'doughnut',
          data: {
            labels: ['Chờ CK', 'Đã CK', 'Hoàn tiền'],
            datasets: [{
              data: [
                paymentBreakdown.awaiting || 0,
                paymentBreakdown.verified || 0,
                paymentBreakdown.refunded || 0
              ],
              backgroundColor: ['#ef4444', '#14b8a6', '#6b7280'],
              borderWidth: 2,
              borderColor: '#fff'
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '60%',
            plugins: {
              legend: { position: 'bottom', labels: { padding: 16, usePointStyle: true, pointStyleWidth: 8 } }
            }
          }
        });
      }

      // ── Donut: Order status ──
      const orderCtx = document.getElementById('orderChart');
      if (orderCtx) {
        new Chart(orderCtx, {
          type: 'doughnut',
          data: {
            labels: ['Chờ xử lý', 'Đã xác nhận', 'Hoàn thành', 'Đã huỷ'],
            datasets: [{
              data: [
                orderBreakdown.pending || 0,
                orderBreakdown.confirmed || 0,
                orderBreakdown.done || 0,
                orderBreakdown.cancelled || 0
              ],
              backgroundColor: ['#f59e0b', '#3b82f6', '#22c55e', '#6b7280'],
              borderWidth: 2,
              borderColor: '#fff'
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '60%',
            plugins: {
              legend: { position: 'bottom', labels: { padding: 16, usePointStyle: true, pointStyleWidth: 8 } }
            }
          }
        });
      }

      // ── Horizontal Bar: Top products (pre-aggregated server-side) ──
      const productsCtx = document.getElementById('productsChart');
      if (productsCtx && topProducts.length > 0) {
        const labels = topProducts.map(p => p.name.length > 25 ? p.name.slice(0, 25) + '…' : p.name);

        new Chart(productsCtx, {
          type: 'bar',
          data: {
            labels,
            datasets: [
              { label: 'Đã CK', data: topProducts.map(p => p.verified), backgroundColor: '#14b8a6' },
              { label: 'Chờ CK', data: topProducts.map(p => p.awaiting), backgroundColor: '#f59e0b' },
              { label: 'Đã huỷ', data: topProducts.map(p => p.cancelled), backgroundColor: '#d1d5db' }
            ]
          },
          options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            scales: {
              x: { stacked: true, grid: { display: false }, ticks: { stepSize: 1 } },
              y: { stacked: true, grid: { display: false } }
            },
            plugins: {
              legend: { position: 'top', labels: { padding: 12, usePointStyle: true, pointStyleWidth: 8 } }
            }
          }
        });
        // Dynamic height based on product count
        if (productsCtx.parentElement) {
          productsCtx.parentElement.style.height = Math.max(200, topProducts.length * 36 + 60) + 'px';
        }
      }

      // ── Revenue bar ──
      const revenueCtx = document.getElementById('revenueChart');
      if (revenueCtx && stats) {
        new Chart(revenueCtx, {
          type: 'bar',
          data: {
            labels: ['Doanh thu'],
            datasets: [
              { label: 'Đã CK', data: [stats.total_revenue], backgroundColor: '#14b8a6' },
              { label: 'Chờ CK', data: [stats.pending_revenue], backgroundColor: '#f59e0b' }
            ]
          },
          options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            scales: {
              x: {
                stacked: true,
                grid: { display: false },
                ticks: { callback: function(v) { return (v / 1000).toLocaleString('vi-VN') + 'k'; } }
              },
              y: { stacked: true, display: false }
            },
            plugins: {
              legend: { position: 'top', labels: { padding: 12, usePointStyle: true, pointStyleWidth: 8 } },
              tooltip: {
                callbacks: {
                  label: function(ctx) { return ctx.dataset.label + ': ' + ctx.raw.toLocaleString('vi-VN') + 'đ'; }
                }
              }
            }
          }
        });
      }
    });
  </script>
)}
