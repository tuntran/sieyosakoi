---
import { env } from 'cloudflare:workers';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getOpenBatch, getOrdersByBatch, updatePaymentStatus, updateOrderStatus } from '../../../lib/db';

const db = env.DB;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('action')?.toString();
  const orderId = form.get('order_id')?.toString();
  if (action === 'verify_payment' && orderId) {
    await updatePaymentStatus(db, orderId, 'verified');
  } else if (action === 'mark_done' && orderId) {
    await updateOrderStatus(db, orderId, 'done');
  }
  return Astro.redirect('/admin/orders');
}

const batch = await getOpenBatch(db);
const params = Astro.url.searchParams;
const filters = {
  batch_id: batch?.id,
  order_status: params.get('order_status') || undefined,
  payment_status: params.get('payment_status') || undefined,
  page: parseInt(params.get('page') || '1'),
};
const orders = batch ? await getOrdersByBatch(db, filters) : [];

function fmtVnd(n: number) { return n.toLocaleString('vi-VN') + 'đ'; }
function fmtDate(ts: number) {
  return new Date(ts * 1000).toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh', day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' });
}

const deliveryShort: Record<string, string> = {
  pickup_practice: 'Buổi tập', pickup_festival_sat: 'LH Thứ 7',
  pickup_festival_sun: 'LH CN', ship_after_27apr: 'Giao hàng',
};
const paymentLabels: Record<string, string> = { awaiting: 'Chờ CK', verified: 'Đã CK', refunded: 'Hoàn tiền' };
const orderLabels: Record<string, string> = { pending: 'Chờ xử lý', confirmed: 'Xác nhận', done: 'Xong', cancelled: 'Huỷ' };
---

<AdminLayout title="Đơn hàng" currentPage="orders">
  <!-- Search bar -->
  <div class="search-bar" style="margin-bottom:8px">
    <div style="position:relative;flex:1;max-width:400px">
      <input type="text" id="order-search" class="form-input" placeholder="Tìm theo tên, SĐT, mã đơn..." style="width:100%;padding-right:32px" />
      <button type="button" id="search-clear" style="position:absolute;right:8px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-muted);font-size:1.1rem;display:none" aria-label="Xóa tìm kiếm">✕</button>
    </div>
    <span id="search-count" style="font-size:0.82rem;color:var(--text-muted);display:none"></span>
  </div>

  <!-- Filter bar -->
  <form method="GET" action="/admin/orders">
    <div class="filter-bar">
      <div class="form-group">
        <label class="form-label">Thanh toán</label>
        <select class="form-select" name="payment_status" style="min-width:130px">
          <option value="">Tất cả</option>
          <option value="awaiting" selected={filters.payment_status === 'awaiting'}>Chờ CK</option>
          <option value="verified" selected={filters.payment_status === 'verified'}>Đã CK</option>
          <option value="refunded" selected={filters.payment_status === 'refunded'}>Hoàn tiền</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Đơn hàng</label>
        <select class="form-select" name="order_status" style="min-width:130px">
          <option value="">Tất cả</option>
          <option value="pending"   selected={filters.order_status === 'pending'}>Chờ xử lý</option>
          <option value="confirmed" selected={filters.order_status === 'confirmed'}>Xác nhận</option>
          <option value="done"      selected={filters.order_status === 'done'}>Xong</option>
          <option value="cancelled" selected={filters.order_status === 'cancelled'}>Huỷ</option>
        </select>
      </div>
      <button type="submit" class="btn btn-primary btn-sm" style="align-self:flex-end">Lọc</button>
      <a href="/admin/orders" class="btn btn-outline btn-sm" style="align-self:flex-end">Reset</a>
    </div>
  </form>

  <div class="card">
    <div class="card-header">
      <span class="card-title">📋 Đơn hàng ({orders.length})</span>
      {orders.length > 0 && (
        <button id="btn-csv-orders" class="btn btn-outline btn-sm" style="margin-left:auto">⬇ Xuất CSV đơn hàng</button>
      )}
    </div>
    {orders.length === 0 ? (
      <div class="card-body" style="color:var(--text-muted)">Không có đơn hàng nào.</div>
    ) : (
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Mã đơn</th>
              <th>Khách hàng</th>
              <th>Nhận hàng</th>
              <th>Tổng tiền</th>
              <th>Thanh toán</th>
              <th>Đơn hàng</th>
              <th>Ngày đặt</th>
              <th>Hành động</th>
            </tr>
          </thead>
          <tbody>
            {orders.map(o => (
              <tr>
                <td><a href={`/admin/orders/${o.id}`} style="font-weight:700">{o.id}</a></td>
                <td>
                  <div style="font-weight:600">{o.customer_name}</div>
                  <div style="font-size:0.78rem;color:var(--text-muted)">{o.phone}</div>
                </td>
                <td style="font-size:0.8rem">{deliveryShort[o.delivery_method] ?? o.delivery_method}</td>
                <td style="font-weight:700">{fmtVnd(o.total)}</td>
                <td><span class={`badge badge-${o.payment_status}`}>{paymentLabels[o.payment_status] ?? o.payment_status}</span></td>
                <td><span class={`badge badge-${o.order_status}`}>{orderLabels[o.order_status] ?? o.order_status}</span></td>
                <td style="font-size:0.78rem;white-space:nowrap">{fmtDate(o.created_at)}</td>
                <td>
                  {o.payment_status === 'awaiting' && (
                    <form action="/admin/orders" method="POST" class="action-form">
                      <input type="hidden" name="action" value="verify_payment" />
                      <input type="hidden" name="order_id" value={o.id} />
                      <button type="submit" class="btn btn-success btn-sm">✓ Duyệt CK</button>
                    </form>
                  )}
                  {o.order_status === 'confirmed' && (
                    <form action="/admin/orders" method="POST" class="action-form">
                      <input type="hidden" name="action" value="mark_done" />
                      <input type="hidden" name="order_id" value={o.id} />
                      <button type="submit" class="btn btn-primary btn-sm">📦 Đã giao</button>
                    </form>
                  )}
                  <a href={`/admin/orders/${o.id}`} class="btn btn-outline btn-sm" style="margin-left:4px">Chi tiết</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Mobile card list (hidden on desktop) -->
      <div class="order-card-list">
        {orders.map(o => (
          <div class="order-card">
            <div class="order-card-top">
              <a href={`/admin/orders/${o.id}`} class="order-card-id">#{o.id}</a>
              <span class="order-card-date">{fmtDate(o.created_at)}</span>
            </div>
            <div class="order-card-customer">
              <strong>{o.customer_name}</strong>
              <span>{o.phone}</span>
            </div>
            <div class="order-card-meta">
              <span class="order-card-total">{fmtVnd(o.total)}</span>
              <span class={`badge badge-${o.payment_status}`}>{paymentLabels[o.payment_status] ?? o.payment_status}</span>
              <span class={`badge badge-${o.order_status}`}>{orderLabels[o.order_status] ?? o.order_status}</span>
            </div>
            <div class="order-card-actions">
              {o.payment_status === 'awaiting' ? (
                <form action="/admin/orders" method="POST" style="flex:1">
                  <input type="hidden" name="action" value="verify_payment" />
                  <input type="hidden" name="order_id" value={o.id} />
                  <button type="submit" class="btn btn-success" style="width:100%">✓ Xác nhận CK</button>
                </form>
              ) : (
                <span class="order-card-ck-done">✓ Đã CK</span>
              )}
              {o.order_status === 'confirmed' && (
                <form action="/admin/orders" method="POST" style="flex:1">
                  <input type="hidden" name="action" value="mark_done" />
                  <input type="hidden" name="order_id" value={o.id} />
                  <button type="submit" class="btn btn-primary" style="width:100%">📦 Đã giao</button>
                </form>
              )}
              <a href={`/admin/orders/${o.id}`} class="btn btn-outline">Chi tiết</a>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>

  <script type="application/json" id="orders-data" set:html={JSON.stringify(orders.map(o => ({
    id: o.id,
    customer: o.customer_name,
    phone: o.phone,
    email: o.email ?? '',
    facebook: o.facebook_url ?? '',
    delivery: o.delivery_method,
    address: o.address ?? '',
    notes: o.notes ?? '',
    order_status: o.order_status,
    payment_status: o.payment_status,
    items: o.items,
    subtotal: o.subtotal,
    shipping_fee: o.shipping_fee,
    total: o.total,
    created_at: o.created_at,
  })))}></script>
  <script>
    const btnOrders = document.getElementById('btn-csv-orders');
    if (btnOrders) {
      const deliveryMap = {
        pickup_practice: 'Buổi tập', pickup_festival_sat: 'LH Thứ 7',
        pickup_festival_sun: 'LH CN', ship_after_27apr: 'Giao hàng',
      };
      const paymentMap = { awaiting: 'Chờ CK', verified: 'Đã CK', refunded: 'Hoàn tiền' };
      const orderMap = { pending: 'Chờ xử lý', confirmed: 'Xác nhận', done: 'Xong', cancelled: 'Huỷ' };
      const fmtDate = (ts) => {
        if (!ts) return '';
        return new Date(ts * 1000).toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh', day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' });
      };

      btnOrders.addEventListener('click', () => {
        const orders = JSON.parse(document.getElementById('orders-data').textContent);
        const headers = ['Mã đơn','Khách hàng','SĐT','Email','Facebook','Nhận hàng','Địa chỉ','Ghi chú','Trạng thái đơn','Thanh toán','Sản phẩm','Màu','Size','Số lượng','Đơn giá','Thành tiền','Phí ship','Tạm tính','Tổng tiền','Ngày đặt'];
        let csv = '\uFEFF' + headers.join(',') + '\n';
        for (const o of orders) {
          for (const item of o.items) {
            const row = [
              o.id,
              o.customer,
              o.phone,
              o.email,
              o.facebook,
              deliveryMap[o.delivery] ?? o.delivery,
              o.address,
              o.notes,
              orderMap[o.order_status] ?? o.order_status,
              paymentMap[o.payment_status] ?? o.payment_status,
              item.name,
              item.color ?? '',
              item.size ?? '',
              item.qty,
              item.unit_price,
              item.qty * item.unit_price,
              o.shipping_fee,
              o.subtotal,
              o.total,
              fmtDate(o.created_at),
            ].map(v => `"${String(v).replace(/"/g, '""')}"`);
            csv += row.join(',') + '\n';
          }
        }
        const a = document.createElement('a');
        a.href = URL.createObjectURL(new Blob([csv], { type: 'text/csv;charset=utf-8' }));
        a.download = 'don-hang.csv';
        a.click();
      });
    }
  </script>

  <!-- Client-side search filter for desktop table + mobile cards -->
  <script>
    {
      const searchInput = document.getElementById('order-search');
      const clearBtn = document.getElementById('search-clear');
      const countEl = document.getElementById('search-count');
      const tableRows = document.querySelectorAll('.data-table tbody tr');
      const mobileCards = document.querySelectorAll('.order-card');

      let debounceTimer;
      searchInput?.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(filterOrders, 300);
      });
      clearBtn?.addEventListener('click', () => {
        if (searchInput) searchInput.value = '';
        filterOrders();
        searchInput?.focus();
      });

      function filterOrders() {
        const keyword = searchInput?.value.toLowerCase().trim() || '';
        clearBtn.style.display = keyword ? 'block' : 'none';
        let visible = 0;
        const total = tableRows.length;

        tableRows.forEach((row, i) => {
          const id = row.querySelector('td a')?.textContent?.toLowerCase() || '';
          const name = row.querySelector('td:nth-child(2) div')?.textContent?.toLowerCase() || '';
          const phone = row.querySelector('td:nth-child(2) div:last-child')?.textContent || '';
          const match = !keyword || id.includes(keyword) || name.includes(keyword) || phone.includes(keyword);
          row.style.display = match ? '' : 'none';
          if (mobileCards[i]) mobileCards[i].style.display = match ? '' : 'none';
          if (match) visible++;
        });

        if (keyword && countEl) {
          countEl.style.display = 'inline';
          countEl.textContent = `${visible}/${total} đơn`;
        } else if (countEl) {
          countEl.style.display = 'none';
        }
      }
    }
  </script>

  <!-- Pagination -->
  {orders.length === 200 && (
    <div class="pagination">
      {filters.page > 1 && (
        <a class="page-btn" href={`/admin/orders?page=${filters.page - 1}&payment_status=${filters.payment_status ?? ''}&order_status=${filters.order_status ?? ''}`}>←</a>
      )}
      <span class="page-btn active">{filters.page}</span>
      <a class="page-btn" href={`/admin/orders?page=${filters.page + 1}&payment_status=${filters.payment_status ?? ''}&order_status=${filters.order_status ?? ''}`}>→</a>
    </div>
  )}
</AdminLayout>
